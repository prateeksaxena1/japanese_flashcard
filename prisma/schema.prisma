// JLPT Vocabulary Learning Platform — Prisma Schema
// Supports N5-N1 levels (N5/N4 active initially)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── JLPT Level ────────────────────────────────────────
model JlptLevel {
  id        String   @id @default(cuid())
  code      String   @unique // N5, N4, N3, N2, N1
  name      String   // e.g. "JLPT N5 — Beginner"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  modules    Module[]
  vocabulary Vocabulary[]

  @@map("jlpt_levels")
}

// ─── Module (chapter/unit within a level) ──────────────
model Module {
  id           String   @id @default(cuid())
  jlptLevelId  String
  moduleNumber Int
  title        String
  description  String?
  sourceBook   String?
  chapterRef   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jlptLevel  JlptLevel    @relation(fields: [jlptLevelId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary[]

  @@unique([jlptLevelId, moduleNumber])
  @@map("modules")
}

// ─── Vocabulary ────────────────────────────────────────
model Vocabulary {
  id               String   @id @default(cuid())
  moduleId         String
  jlptLevelId      String
  kanji            String?
  hiragana         String
  katakana         String?
  romaji           String
  primaryMeaning   String
  acceptedMeanings Json     @default("[]") // string[]
  synonyms         Json     @default("[]") // string[]
  partOfSpeech     String?
  difficultyScore  Int      @default(1) // 1-5
  tags             Json     @default("[]") // string[]
  audioUrl         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  module    Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  jlptLevel JlptLevel @relation(fields: [jlptLevelId], references: [id], onDelete: Cascade)

  userProgress      UserProgress[]
  flashcardAttempts  FlashcardAttempt[]

  @@map("vocabulary")
}

// ─── User ──────────────────────────────────────────────
enum UserRole {
  STUDENT
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String    @unique
  passwordHash String
  role         UserRole  @default(STUDENT)
  timezone     String    @default("Asia/Tokyo")
  createdAt    DateTime  @default(now())
  lastActive   DateTime?

  progress          UserProgress[]
  flashcardSessions FlashcardSession[]
  flashcardAttempts FlashcardAttempt[]
  streak            UserStreak?

  @@map("users")
}

// ─── User Progress (per vocabulary item) ───────────────
model UserProgress {
  id               String    @id @default(cuid())
  userId           String
  vocabularyId     String
  correctCount     Int       @default(0)
  incorrectCount   Int       @default(0)
  partialCount     Int       @default(0)
  lastReviewedAt   DateTime?
  nextReviewAt     DateTime?
  easeFactor       Float     @default(2.5)
  intervalDays     Int       @default(1)
  repetitionNumber Int       @default(0)
  masteryLevel     Int       @default(0)
  streakCount      Int       @default(0)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyId])
  @@map("user_progress")
}

// ─── Flashcard Session ─────────────────────────────────
enum SessionType {
  PRACTICE
  TEST
  REVIEW
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model FlashcardSession {
  id              String        @id @default(cuid())
  userId          String
  sessionType     SessionType   @default(PRACTICE)
  displayMode     String        @default("kanji") // kanji, hiragana, or romaji
  selectedModules Json          @default("[]") // string[] of module IDs
  totalCards      Int           @default(0)
  completedCards  Int           @default(0)
  scoreTotal      Float         @default(0)
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  status          SessionStatus @default(IN_PROGRESS)

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts FlashcardAttempt[]

  @@map("flashcard_sessions")
}

// ─── Flashcard Attempt ─────────────────────────────────
enum EvaluationMethod {
  EXACT
  SYNONYM
  FUZZY
  SEMANTIC
  STEM
}

model FlashcardAttempt {
  id               String           @id @default(cuid())
  sessionId        String
  userId           String
  vocabularyId     String
  userInput        String
  correctAnswer    String
  rawScore         Float            @default(0)
  evaluationMethod EvaluationMethod @default(EXACT)
  timeTakenMs      Int              @default(0)
  createdAt        DateTime         @default(now())

  session    FlashcardSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary       @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@map("flashcard_attempts")
}

// ─── User Streak ───────────────────────────────────────
model UserStreak {
  id               String   @id @default(cuid())
  userId           String   @unique
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  lastActivityDate DateTime?
  totalDaysActive  Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}
